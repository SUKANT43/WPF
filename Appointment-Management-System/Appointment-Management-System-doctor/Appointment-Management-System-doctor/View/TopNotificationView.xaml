<UserControl x:Class="Appointment_Management_System_doctor.View.TopNotificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Appointment_Management_System_doctor.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border x:Name="NotificationBorder"
            Background="#14B8A6"
            CornerRadius="10"
            Padding="15,10"
            MinWidth="250"
            MaxWidth="450">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="MessageText"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                    <Button Grid.Column="1"
                        Style="{StaticResource RoundedButton}"
                        Content="✕"
                        Width="50"
                        Height="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Close_Click"/>
                </Grid>

                <ProgressBar x:Name="TimerProgressBar"
                         Grid.Row="1"
                         Height="50"
                         Minimum="0"
                         Maximum="100"
                         Value="100"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
