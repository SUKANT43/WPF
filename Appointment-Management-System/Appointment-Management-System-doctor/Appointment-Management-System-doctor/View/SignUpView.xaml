<UserControl x:Class="Appointment_Management_System_doctor.View.SignUpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F7FA">

        <Border Margin="40"
                CornerRadius="25"
                Background="White">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT IMAGE PANEL -->
                <Border Grid.Column="0"
                        Background="#E8F8FA"
                        CornerRadius="25,0,0,25">

                    <Grid>

                        <!-- Curved Shape Background -->
                        <Border Background="#D7F4F7"
                                CornerRadius="0,0,120,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                Height="180"/>

                        <!-- Doctor Image -->
                        <Image Source="/Resources/Images/doctor.png"
                               Width="420"
                               Height="420"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,-20,0,40"/>

                        <!-- Bottom Text -->
                        <StackPanel VerticalAlignment="Bottom"
                                    Margin="40,0,40,40">

                            <TextBlock Text="Your Health, Our Priority"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"
                                       TextAlignment="Center"/>

                            <TextBlock Text="Manage appointments, patient records, and healthcare services with ease."
                                       FontSize="15"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- RIGHT LOGIN PANEL -->
                <Grid Grid.Column="1"
                      Margin="60">

                    <StackPanel VerticalAlignment="Center">

                        <Viewbox Width="280"
                                 Height="150"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,20">
                            <Image Source="/Resources/Images/logo.png"/>
                        </Viewbox>
                        <TextBlock Text="Welcome Back"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#374151"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Please enter your details"
                                   FontSize="16"
                                   Foreground="#6B7280"
                                   Margin="0,0,0,30"/>

                        <TextBlock Text="Name"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,20">
                            <TextBox Height="45"
                                     Padding="12"
                                     BorderThickness="0"
                                     Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"/>
                        </Border>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,20">
                            <TextBox Height="45"
                                     Padding="12"
                                     BorderThickness="0"
                                     Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"/>
                        </Border>


                        <TextBlock Text="Password"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,20">
                            <PasswordBox Height="45"
                                         x:Name="passwordBox"
                                         Padding="12"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                        </Border>

                        <TextBlock Text="Confirm Password"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,20">
                            <PasswordBox Height="45"
                                         Padding="12"
                                         BorderThickness="0"
                                         x:Name="confirmPasswordBox"
                                         Background="Transparent"/>
                        </Border>




                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Message}" Foreground="Red"/>

                        </Grid>

                        <Button Content="Sign Up"
                                Height="50"
                                Background="#14B8A6"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="16"
                                BorderThickness="0"
                                Style="{StaticResource RoundedButton}"
                                Command="{Binding SignupCommand}"/>
                        <StackPanel Margin="0,20,0,0"
            HorizontalAlignment="Center">
                            <TextBlock FontSize="14"
               Foreground="#6B7280"
               TextAlignment="Center">
        Already have an account?
        <Hyperlink 
                                Command="{Binding GoToLoginCommand}"
            
                   Foreground="#14B8A6">
            Sign In
        </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>


                </Grid>
                <StackPanel>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>


</UserControl>