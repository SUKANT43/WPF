<UserControl x:Class="Appointment_Management_System_doctor.Components.TopBarComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Appointment_Management_System_doctor.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Height="70" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Logo -->
        <StackPanel Grid.Column="0"
                Orientation="Vertical"
                VerticalAlignment="Center"
                Margin="20,12,5,6" Height="52">
            <Image Source="/Resources/Images/logo.png"
               Height="89"
               Stretch="Uniform"
               Margin="-8,0,-5,0"/>

        </StackPanel>

        <!-- Navigation -->
        <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">
            <Button Content="Dashboard"
                Width="90"
                Height="35"
                Margin="5"
                Background="Transparent"
                BorderThickness="0"
                FontWeight="SemiBold"/>

            <Button Content="Calendar"
                Width="80"
                Height="35"
                Margin="5"
                Background="Transparent"
                BorderThickness="0"
                FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Search -->
        <Border Grid.Column="2"
            Width="300"
            Height="40"
            CornerRadius="20"
            Background="#F5F5F5"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
            <TextBox BorderThickness="0"
                 Background="Transparent"
                 VerticalContentAlignment="Center"
                 Padding="15,0"
                 FontSize="14"
                 Text="Search patients..."/>
        </Border>

        <!-- Right section -->
        <StackPanel Grid.Column="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,20,0">

            <Button Width="40"
                Height="40"
                Margin="5"
                Content="🔔"
                FontSize="18"
                Background="#F5F5F5"
                BorderThickness="0"/>


            <Border Width="40"
                Height="40"
                Margin="5"
                CornerRadius="20"
                Background="#D9D9D9">
                <TextBlock Text="👨‍⚕️"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
