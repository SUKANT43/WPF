<Window x:Class="Appointment_Management_System_doctor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Appointment_Management_System_doctor"
        xmlns:view="clr-namespace:Appointment_Management_System_doctor.View"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ContentControl Content="{Binding CurrentView}"/>
        <view:TopNotificationView x:Name="GlobalNotification"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Center"
                          Panel.ZIndex="100"/>
    </Grid>
</Window>
