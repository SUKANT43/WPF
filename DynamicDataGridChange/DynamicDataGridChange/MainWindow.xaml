<Window x:Class="DynamicDataGridChange.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DynamicDataGridChange"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Button Click="ButtonXClick" x:Name="x" Content="X"/>
            <Button Click="ButtonYClick" x:Name="y" Content="Y"/>
            <Button Click="ButtonZClick" x:Name="z"  Content="Z"/>
        </StackPanel>

        <DataGrid x:Name="dataGrid" ColumnWidth="*" Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding Rows}">
            
        </DataGrid>
        
    </Grid>
</Window>
