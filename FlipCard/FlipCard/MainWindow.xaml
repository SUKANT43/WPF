<Window x:Class="FlipCard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlipCard"
        xmlns:control="clr-namespace:FlipCard.Controls"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="600"
        Width="900"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <control:ThemeControl Grid.Row="0"/>

        <!-- Product Card -->

        <WrapPanel Grid.Row="1">
            <control:ProductDisplayCard 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ProductName="Apple Watch Series 7 Steel"
                                    ImageSource="C:\Users\SEZ-A4\Desktop\Wpf\WPF\FlipCard\FlipCard\Image/apple.png"
                                    OfferedPrice="299"
                                    OriginalPrice="39999"
                                    RatingCount="3595"
                                    IsPriceIncreased="True"
                                    IsOutOfStock="False"
                                    Width="380"
                                    Height="450"
                                    ProductDescription="Experience the future of health monitoring with advanced sensors, seamless connectivity, and a stunning Always-On Retina display. Designed for fitness, health tracking, and everyday productivity.">

                <control:ProductDisplayCard.ProductFeatures>
                    <sys:String>Retina Always-On Display</sys:String>
                    <sys:String>Blood Oxygen Sensor</sys:String>
                    <sys:String>ECG App Support</sys:String>
                    <sys:String>Fast Charging Capability</sys:String>
                    <sys:String>Water Resistant Design</sys:String>
                </control:ProductDisplayCard.ProductFeatures>
                
                

            </control:ProductDisplayCard>
          



        </WrapPanel>
        
    </Grid>
</Window>