<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#f1f5f9"/>
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#ffffff"/>

    <SolidColorBrush x:Key="DividerBrush" Color="#e2e8f0"/>


    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="CardSecondaryBackgroundBrush" Color="#f8fafc"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#e2e8f0"/>


    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1e293b"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#475569"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748b"/>


    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#3b82f6"/>
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#2563eb"/>

    <SolidColorBrush x:Key="BuyNowButtonBrush" Color="#fb923c"/>
    <SolidColorBrush x:Key="BuyNowButtonHoverBrush" Color="#f97316"/>


    <SolidColorBrush x:Key="DiscountBadgeBrush" Color="#ef4444"/>
    <SolidColorBrush x:Key="DiscountTextBrush" Color="#16a34a"/>

    <SolidColorBrush x:Key="InStockBrush" Color="#16a34a"/>
    <SolidColorBrush x:Key="OutOfStockBrush" Color="#dc2626"/>


    <SolidColorBrush x:Key="BackOuterBrush" Color="#e2e8f0"/>
    <SolidColorBrush x:Key="BackInnerBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="BackContentBrush" Color="#ffffff"/>


    <SolidColorBrush x:Key="ThemeIconBrush" Color="#1e293b"/>

    <LinearGradientBrush x:Key="CardImageBackgroundBrush"
                     StartPoint="0,0"
                     EndPoint="1,1">
        <GradientStop Color="#f8fafc" Offset="0"/>
        <GradientStop Color="#e2e8f0" Offset="0.5"/>
        <GradientStop Color="#cbd5e1" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TopBarBackColor" Color="#cdd6e2"/>

</ResourceDictionary>