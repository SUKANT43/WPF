<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0f172a"/>
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#1e293b"/>

    <SolidColorBrush x:Key="DividerBrush" Color="#334155"/>


    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1e293b"/>
    <SolidColorBrush x:Key="CardSecondaryBackgroundBrush" Color="#0f172a"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>


    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#f1f5f9"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#cbd5e1"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94a3b8"/>


    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#3b82f6"/>
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#2563eb"/>

    <SolidColorBrush x:Key="BuyNowButtonBrush" Color="#fb923c"/>
    <SolidColorBrush x:Key="BuyNowButtonHoverBrush" Color="#f97316"/>


    <SolidColorBrush x:Key="DiscountBadgeBrush" Color="#ef4444"/>
    <SolidColorBrush x:Key="DiscountTextBrush" Color="#4ade80"/>

    <SolidColorBrush x:Key="InStockBrush" Color="#22c55e"/>
    <SolidColorBrush x:Key="OutOfStockBrush" Color="#f87171"/>


    <SolidColorBrush x:Key="BackOuterBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="BackInnerBrush" Color="#1e293b"/>
    <SolidColorBrush x:Key="BackContentBrush" Color="#1e293b"/>


    <SolidColorBrush x:Key="ThemeIconBrush" Color="#facc15"/>

    <LinearGradientBrush x:Key="CardImageBackgroundBrush"
                     StartPoint="0,0"
                     EndPoint="1,1">
        <GradientStop Color="#1e293b" Offset="0"/>
        <GradientStop Color="#1b2638" Offset="0.5"/>
        <GradientStop Color="#0f172a" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TopBarBackColor" Color="#1e293b"/>


</ResourceDictionary>