<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:FlipCard.Controls"
    xmlns:helper="clr-namespace:FlipCard.Helper">

    <local:StarHighlightConverter x:Key="StarHighlightConverter"/>

    <Style TargetType="{x:Type local:ProductDisplayCard}">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ProductDisplayCard}">

                    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">

                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="FlipScale" ScaleX="1"/>
                        </Grid.RenderTransform>

                        <!-- FRONT SIDE -->
                        <Border x:Name="FrontCard"
                                Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="20"
                                Padding="16">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- IMAGE SECTION -->
                                <Grid Grid.Row="0">
                                    <Border CornerRadius="5"
                                            Background="{DynamicResource CardImageBackgroundBrush}">

                                        <Image Source="{Binding ImageSource, RelativeSource={RelativeSource TemplatedParent}}"
                                               Width="200"
                                               Height="180"/>
                                    </Border>

                                    <!-- Discount Badge -->
                                    <Border Background="{DynamicResource DiscountBadgeBrush}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="2"
                                            CornerRadius="8"
                                            Panel.ZIndex="3"
                                            Visibility="{Binding IsDiscountPercentageVisible,
                                                         RelativeSource={RelativeSource AncestorType=Control}}">
                                        <TextBlock Text="{Binding DiscountPercentage,
                                                          RelativeSource={RelativeSource TemplatedParent},
                                                          StringFormat={}{0}% OFF}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Padding="6 3"/>
                                    </Border>

                                    <Button VerticalAlignment="Top"
                                            HorizontalAlignment="Right"
                                            Margin="4"
                                            Background="Transparent"
                                            x:Name="likeButton">

                                        <StackPanel>
                                            <Image Source="{Binding HeartPngSource,
                                                         RelativeSource={RelativeSource TemplatedParent}}"
                                                   Width="30"/>
                                        </StackPanel>

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                    </Button>
                                </Grid>

                                <!-- NAME + RATING -->
                                <StackPanel Grid.Row="1">

                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding ProductName,
                                               RelativeSource={RelativeSource AncestorType=Control}}"
                                               FontWeight="Bold"
                                               TextWrapping="WrapWithOverflow"
                                               FontSize="20"/>

                                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0">

                                        <StackPanel Orientation="Horizontal" x:Name="stars">

                                            <ItemsControl ItemsSource="{Binding StarItems, RelativeSource={RelativeSource TemplatedParent}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="★"
                                                                   FontSize="18"
                                                                   Margin="2"
                                                                   Cursor="Hand">

                                                            <TextBlock.Foreground>
                                                                <MultiBinding Converter="{StaticResource StarHighlightConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="Rating"
                                                                             RelativeSource="{RelativeSource AncestorType=local:ProductDisplayCard}"/>
                                                                </MultiBinding>
                                                            </TextBlock.Foreground>

                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>

                                            </ItemsControl>

                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Text="(" Foreground="{DynamicResource MutedTextBrush}" FontSize="13"/>
                                            <TextBlock Text="{Binding RatingCount,
                                                              RelativeSource={RelativeSource AncestorType=Control}}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text=")" FontSize="13" Foreground="{DynamicResource MutedTextBrush}"/>
                                        </StackPanel>

                                    </StackPanel>
                                </StackPanel>

                                <!-- PRICE SECTION -->
                                <StackPanel Grid.Row="2">

                                    <StackPanel Orientation="Horizontal">

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="₹"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       helper:HighLightHelper.IsHighlighted="{Binding IsPriceIncreased,
                                                                                             RelativeSource={RelativeSource TemplatedParent}}"/>

                                            <TextBlock Text="{Binding OfferedPrice,
                                                              RelativeSource={RelativeSource TemplatedParent}}"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       helper:HighLightHelper.IsHighlighted="{Binding IsPriceIncreased,
                                                                                             RelativeSource={RelativeSource TemplatedParent}}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="7 4 0 0">
                                            <TextBlock Text="₹"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="15">
                                                <TextBlock.TextDecorations>
                                                    <TextDecorationCollection>
                                                        <TextDecoration Location="Strikethrough"/>
                                                    </TextDecorationCollection>
                                                </TextBlock.TextDecorations>
                                            </TextBlock>

                                            <TextBlock Text="{Binding OriginalPrice,
                                                              RelativeSource={RelativeSource AncestorType=Control}}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="15">
                                                <TextBlock.TextDecorations>
                                                    <TextDecorationCollection>
                                                        <TextDecoration Location="Strikethrough"/>
                                                    </TextDecorationCollection>
                                                </TextBlock.TextDecorations>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="10 5 0 0"
                                                    Visibility="{Binding IsDiscountPercentageVisible,
                                                                 RelativeSource={RelativeSource AncestorType=Control}}">
                                            <TextBlock Text="{Binding DiscountPercentage,
                                                              RelativeSource={RelativeSource TemplatedParent}}"
                                                       Foreground="{DynamicResource DiscountTextBrush}"
                                                       FontSize="14"/>
                                            <TextBlock Text="%"
                                                       Foreground="{DynamicResource DiscountTextBrush}"
                                                       FontSize="14"/>
                                            <TextBlock Text="off"
                                                       Margin="5 0 0 0"
                                                       Foreground="{DynamicResource DiscountTextBrush}"
                                                       FontSize="14"/>
                                        </StackPanel>

                                    </StackPanel>
                                </StackPanel>

                                <!-- STOCK -->
                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Margin="0 6 0 0">

                                    <Border CornerRadius="100"
                                            Width="8"
                                            Height="8"
                                            Background="{DynamicResource InStockBrush}"
                                            helper:StockHelper.IsOutOfStock="{Binding IsOutOfStock,
                                                                              RelativeSource={RelativeSource AncestorType=Control}}"/>

                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="4 0 0 0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               helper:StockHelper.IsOutOfStock="{Binding IsOutOfStock,
                                                                                RelativeSource={RelativeSource AncestorType=Control}}"/>
                                </StackPanel>

                                <!-- BUTTON -->
                                <Button Content="Add to Cart"
                                        Grid.Row="4"
                                        Margin="0 5 0 0"
                                        Foreground="White"
                                        Background="{DynamicResource PrimaryButtonBrush}"
                                        FontWeight="Bold"
                                        Padding="7"
                                        helper:StockHelper.IsOutOfStock="{Binding IsOutOfStock,
                                                                          RelativeSource={RelativeSource AncestorType=Control}}">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="8"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>

                                </Button>

                            </Grid>
                        </Border>

                        <!-- BACK SIDE -->
                        <Grid x:Name="BackCard"
                              Visibility="Collapsed">

                            <Border Background="{DynamicResource BackOuterBrush}"
                                    CornerRadius="20"/>

                            <Border Background="{DynamicResource BackInnerBrush}"
                                    Margin="12"
                                    CornerRadius="20"/>

                            <Viewbox Margin="20">
                                <Path Fill="{DynamicResource BackContentBrush}"
                                      Stretch="Fill"
                                      Data="
                                      M0,20
                                      Q0,0 20,0
                                      L280,0
                                      Q300,0 300,20
                                      L300,330
                                      Q300,350 280,350
                                      L20,350
                                      Q0,350 0,330
                                      Z"/>
                            </Viewbox>

                            <Grid Margin="50">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Product Details"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <Border Height="2"
                                            Margin="0,12,0,0"
                                            Background="{DynamicResource DividerBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,20,0,0"
                                           Text="{Binding ProductDescription,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="14"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>

                                <ItemsControl Grid.Row="2"
                                              Margin="0,20,0,0"
                                              ItemsSource="{Binding ProductFeatures,
                                                            RelativeSource={RelativeSource TemplatedParent}}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Fill="{DynamicResource InStockBrush}"
                                                         Margin="0,0,10,0"
                                                         VerticalAlignment="Center"/>

                                                <TextBlock Text="{Binding}"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                                <Button Grid.Row="3"
                                        Content="Buy Now"
                                        Height="45"
                                        Margin="0,30,0,0"
                                        Background="{DynamicResource BuyNowButtonBrush}"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Left"
                                        Width="150"
                                        helper:StockHelper.IsOutOfStock="{Binding IsOutOfStock,
                                                                          RelativeSource={RelativeSource AncestorType=Control}}">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="25"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>

                                </Button>

                            </Grid>

                        </Grid>

                    </Grid>

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsFlipped" Value="True">
                            <Setter TargetName="FrontCard" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="BackCard" Property="Visibility" Value="Visible"/>

                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FlipScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="1"
                                                         To="0"
                                                         Duration="0:0:0.15"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <Trigger Property="IsFlipped" Value="False">
                            <Setter TargetName="FrontCard" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="BackCard" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>