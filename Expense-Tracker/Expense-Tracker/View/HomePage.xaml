<UserControl x:Class="Expense_Tracker.View.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:component="clr-namespace:Expense_Tracker.Component"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1000"
             Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="20">

        <!-- Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- Top Bar -->
        <component:TopBarComponent Grid.Row="0" Grid.ColumnSpan="2"/>


        <!-- Summary Cards -->
        <component:ExpenseInformationCard Grid.Row="1"
                                          Grid.ColumnSpan="2"
                                          Margin="0,15,0,20"/>


        <!-- Add Transaction -->
        <component:ExpenseCardComponent Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.RowSpan="2"/>


        <!-- Right Side -->
        <Grid Grid.Row="2"
              Grid.Column="1"
              Margin="20,0,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter -->
            <component:FilterComponent Grid.Row="0"
                                       Margin="0,0,0,15"/>

            <!-- Transactions -->
            <StackPanel Grid.Row="1">
                <component:TransactionDetailsComponent/>
                <component:TransactionDetailsComponent/>
                <component:TransactionDetailsComponent/>

            </StackPanel>

        </Grid>

    </Grid>

</UserControl>