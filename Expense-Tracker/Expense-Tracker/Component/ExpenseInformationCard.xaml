<UserControl x:Class="Expense_Tracker.Component.ExpenseInformationCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>


        <!-- Total Balance Card -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,10,0"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Total Balance"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Grid.Column="1"
                               Text="$"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">

                    <TextBlock Text="$3,618"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#16A34A"/>

                    <TextBlock Text="+ Current balance"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>

                </StackPanel>

            </Grid>
        </Border>


        <!-- Total Income Card -->
        <Border Grid.Column="1"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="18"
                Margin="10,0"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Total Income"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Grid.Column="1"
                               Text="📈"
                               FontSize="14"
                               Foreground="#16A34A"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">

                    <TextBlock Text="$4,200"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#16A34A"/>

                    <TextBlock Text="3 transactions"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>

                </StackPanel>

            </Grid>
        </Border>


        <!-- Total Expenses Card -->
        <Border Grid.Column="2"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="18"
                Margin="10,0,0,0"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Total Expenses"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Grid.Column="1"
                               Text="📉"
                               FontSize="14"
                               Foreground="#DC2626"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">

                    <TextBlock Text="$582"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#DC2626"/>

                    <TextBlock Text="3 transactions"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>

</UserControl>