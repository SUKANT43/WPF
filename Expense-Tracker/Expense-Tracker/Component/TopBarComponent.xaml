<UserControl x:Class="Expense_Tracker.Component.TopBarComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBackgroundBrush}"
             Height="70">

    <Border BorderBrush="{DynamicResource BorderBrushColor}"
            BorderThickness="0,0,0,1"
            Padding="20,10">

        <Grid VerticalAlignment="Center">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left Section -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- App Icon -->
                <Border Width="36"
                        Height="36"
                        CornerRadius="8"
                        Background="{DynamicResource PrimaryButtonBrush}"
                        Margin="0,0,10,0"
                        Cursor="Hand">

                    <TextBlock Text="💳"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryButtonTextBrush}"/>
                </Border>

                <StackPanel>
                    <TextBlock Text="ExpenseTracker"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <TextBlock Text="Welcome back, sukant"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"/>
                </StackPanel>

            </StackPanel>


            <!-- Right Section -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Theme Toggle -->
                <Button x:Name="ThemeToggleBtn"
                        Width="40"
                        Height="30"
                        Click="ThemeToggleBtn_Click"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20">

                    <TextBlock x:Name="themeText"
                               Text="🌙"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>


                <!-- Reports Button -->
                <Button Background="{DynamicResource InputBackgroundBrush}"
                        BorderThickness="0"
                        Padding="12,6"
                        Cursor="Hand"
                        Margin="10,0,0,0">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊"
                                   Margin="0,0,5,0"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Reports"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="20"
                                    Background="{TemplateBinding Background}"
                                    Padding="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>


                <!-- Avatar -->
                <Border Width="32"
                        Height="32"
                        CornerRadius="16"
                        Background="{DynamicResource UserProfileBackGround}"
                        Margin="10,0,0,0">

                    <TextBlock Text="S"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Border>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>