<UserControl x:Class="Expense_Tracker.Component.TransactionDetailsComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="12"
            Padding="14"
            BorderBrush="{DynamicResource BorderBrushColor}"
            BorderThickness="1"
            Margin="0 0 0 10">

        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ICON -->
            <Border Grid.Column="0"
                    Width="42"
                    Height="42"
                    CornerRadius="100"
                    Background="{DynamicResource IncomeIconBackgroundBrush}"
                    VerticalAlignment="Center">

                <TextBlock Text="↗"
                           FontSize="20"
                           Foreground="{DynamicResource IncomeIconBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- TRANSACTION DETAILS -->
            <StackPanel Grid.Column="1"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="We"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,10,0"/>

                    <Border Background="{DynamicResource CategoryBackgroundBrush}"
                            CornerRadius="8"
                            Padding="6,2">

                        <TextBlock Text="Salary"
                                   FontSize="12"
                                   Foreground="{DynamicResource CategoryTextBrush}"/>
                    </Border>

                </StackPanel>

                <TextBlock Text="2/24/2026"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

            </StackPanel>

            <!-- ACTION AREA -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="+$500"
                           FontWeight="Bold"
                           Foreground="{DynamicResource IncomeAmountBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <TextBlock Text="✏" FontSize="16"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Button>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <TextBlock Text="🗑"
                               FontSize="16"
                               Foreground="{DynamicResource DangerBrush}"/>
                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>