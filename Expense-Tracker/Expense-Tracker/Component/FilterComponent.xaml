<UserControl x:Class="Expense_Tracker.Component.FilterComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="12"
            Padding="20"
            BorderBrush="{DynamicResource BorderBrushColor}"
            BorderThickness="1">

        <StackPanel>

            <!-- Title -->
            <TextBlock Text="Filter Transactions"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- From Date -->
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="From"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <DatePicker Height="32"/>
                </StackPanel>


                <!-- To Date -->
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="To"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <DatePicker Height="32"/>
                </StackPanel>


                <!-- Type -->
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Type"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <ComboBox Height="32">
                    <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Income"/>
                        <ComboBoxItem Content="Expense"/>
                    </ComboBox>
                </StackPanel>


                <!-- Category -->
                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Category"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <ComboBox Height="32">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Food"/>
                        <ComboBoxItem Content="Transport"/>
                        <ComboBoxItem Content="Shopping"/>
                        <ComboBoxItem Content="Bills"/>
                    </ComboBox>
                </StackPanel>


                <!-- Clear Button -->
                <Button Grid.Column="4"
                        Content="Clear"
                        Height="32"
                        Padding="15,0"
                        Background="{DynamicResource PrimaryButtonBrush}"
                        Foreground="{DynamicResource PrimaryButtonTextBrush}"
                        BorderThickness="0"
                        VerticalAlignment="Bottom"
                        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    Padding="9">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </Grid>

        </StackPanel>

    </Border>

</UserControl>