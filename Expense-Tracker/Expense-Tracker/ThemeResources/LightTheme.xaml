<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="White"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrushColor" Color="#E5E7EB"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#020617"/>
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="White"/>

    <SolidColorBrush x:Key="UserProfileBackGround" Color="White"/>
    <SolidColorBrush x:Key="UserProfileForeGround" Color="Black"/>

    <SolidColorBrush x:Key="IncomeIconBackgroundBrush" Color="#DBFCE7"/>
    <SolidColorBrush x:Key="IncomeIconBrush" Color="#16A34A"/>

    <SolidColorBrush x:Key="CategoryBackgroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="CategoryTextBrush" Color="#374151"/>

    <SolidColorBrush x:Key="IncomeAmountBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>

</ResourceDictionary>